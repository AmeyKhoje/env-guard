  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",

    "outDir": "./dist",
    "rootDir": "./src",

    "declaration": true,
    "emitDeclarationOnly": true,

    "strict": true,
    "types": ["node"]
