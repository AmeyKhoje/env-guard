{
  "name": "@ameykhoje/env-guard",
  "version": "1.0.3",
  "description": "Type-safe environment validation library",
  "license": "MIT",
  "author": "Amey Khoje",
  "files": [
    "dist"
  ],
  "keywords": [
    "env",
    "type-safe",
    "type safety",
    "env validation",
    "env type safety",
    "env guard"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:watch": "vite build -w",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.8.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
